# Copie para a raiz do monorepo (pasta module-hub): cp .env.docker.example ../.env

DB_USERNAME=modulehub
DB_PASSWORD=modulehub
DB_DATABASE=module_hub
DB_PORT=5432
REDIS_PORT=6379
NODE_ENV=development
API_PORT=3000
WEB_PORT=8080
FRONTEND_URL=http://localhost:8080
VITE_API_URL=http://localhost:3000/api
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32
RUN_MIGRATIONS=true
RUN_SEED=true
