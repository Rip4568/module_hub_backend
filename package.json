  "main": "index.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:run-migration": "npm run typeorm migration:run -- -d src/data-source.ts",
    "typeorm:generate-migration": "npm run typeorm migration:generate -- -d src/data-source.ts",
    "typeorm:revert-migration": "npm run typeorm migration:revert -- -d src/data-source.ts",
    "typeorm:create-migration": "npm run typeorm migration:create"
  },
